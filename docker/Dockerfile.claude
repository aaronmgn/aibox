# Claude Code on top of the shared base.
#
# The CLI is installed under /opt (NOT under /home/aibox) and symlinked onto the
# system PATH. This matters: /home/aibox is replaced by a named volume at runtime,
# which would shadow anything installed there and pin a stale version across
# rebuilds. The binary writes user credentials to $HOME/.claude (the volume) at
# runtime, while its own program files live in the image at /opt.
FROM aibox-base:latest

USER root

# The installer drops a launcher symlink at $TOOL_HOME/.local/bin/claude pointing
# to a versioned binary under $TOOL_HOME/.local/share. Resolve it and link the real
# binary onto the system PATH. The binary self-locates its files via /proc/self/exe
# and reads user credentials from $HOME/.claude (the volume) at runtime.
RUN set -eux; \
    export TOOL_HOME=/opt/aibox-tools; \
    mkdir -p "$TOOL_HOME"; \
    HOME="$TOOL_HOME" sh -c 'curl -fsSL https://claude.ai/install.sh | bash'; \
    target="$(readlink -f "$TOOL_HOME/.local/bin/claude")"; \
    test -x "$target"; \
    ln -sf "$target" /usr/local/bin/claude; \
    chmod -R a+rX "$TOOL_HOME"; \
    HOME=/tmp/verify claude --version; \
    rm -rf /tmp/verify

CMD ["claude"]
