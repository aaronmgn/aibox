# Codex on top of the shared base.
#
# Codex ships as a static Rust binary. Installed under /opt (NOT under
# /home/aibox, which the named volume shadows at runtime) and symlinked onto the
# system PATH. Credentials are written to $HOME/.codex (the volume) at runtime.
FROM aibox-base:latest

USER root

# The installer drops a launcher symlink at $TOOL_HOME/.local/bin/codex pointing to
# the real binary under $TOOL_HOME/.codex/packages. Resolve it and link the real
# binary onto the system PATH. It self-locates its resources via /proc/self/exe and
# reads user credentials from $HOME/.codex (the volume) at runtime.
RUN set -eux; \
    export TOOL_HOME=/opt/aibox-tools; \
    mkdir -p "$TOOL_HOME"; \
    HOME="$TOOL_HOME" sh -c 'curl -fsSL https://chatgpt.com/codex/install.sh | sh'; \
    target="$(readlink -f "$TOOL_HOME/.local/bin/codex")"; \
    test -x "$target"; \
    ln -sf "$target" /usr/local/bin/codex; \
    chmod -R a+rX "$TOOL_HOME"; \
    HOME=/tmp/verify codex --version; \
    rm -rf /tmp/verify

# Don't attribute commits to Codex. Codex only adds a "Co-authored-by: Codex"
# trailer when features.codex_git_commit is on (off by default). Pin it off in the
# system config (default layer) AND enforce it un-overridably via requirements.toml,
# and empty the trailer as belt-and-suspenders. Baked at /etc/codex, which Codex
# reads outside CODEX_HOME, so the ~/.codex volume can't shadow it.
# Note: commit_attribution is a TOP-LEVEL key and must precede the [features] table.
RUN mkdir -p /etc/codex \
 && printf '%s\n' \
      'commit_attribution = ""' \
      '' \
      '[features]' \
      'codex_git_commit = false' \
      > /etc/codex/config.toml \
 && printf '%s\n' \
      '[features]' \
      'codex_git_commit = false' \
      > /etc/codex/requirements.toml

CMD ["codex"]
