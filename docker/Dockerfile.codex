# Codex on top of the shared base.
#
# Codex ships as a static Rust binary. Installed under /opt (NOT under
# /home/aibox, which the named volume shadows at runtime) and symlinked onto the
# system PATH. Credentials are written to $HOME/.codex (the volume) at runtime.
FROM aibox-base:latest

USER root

RUN set -eux; \
    export TOOL_HOME=/opt/aibox-tools; \
    mkdir -p "$TOOL_HOME"; \
    HOME="$TOOL_HOME" sh -c 'curl -fsSL https://chatgpt.com/codex/install.sh | sh'; \
    bin="$(find "$TOOL_HOME" -type f -name codex -perm -u+x 2>/dev/null | head -1)"; \
    test -n "$bin"; \
    ln -sf "$bin" /usr/local/bin/codex; \
    chmod -R a+rX "$TOOL_HOME"; \
    codex --version

CMD ["codex"]
